{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SIK Render",
  "version": "1.1.1",
  "identifier": "com.sik.render",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "bun run generate",
    "frontendDist": "../.output/public"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SIK Render Manager",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: data: blob: http://asset.localhost https://asset.localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob: http: https:; media-src 'self' asset: data: blob: http: https:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost tauri: asset: data: blob: http://asset.localhost https://asset.localhost;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*.png",
          "**/*.jpg",
          "**/*.jpeg",
          "**/*.webp",
          "**/*.bmp",
          "**/*.tga",
          "**/*.tiff",
          "**/*.hdr",
          "**/*.exr",
          "**/*.mp4",
          "**/*.m4v",
          "**/*.webm",
          "**/*.mov",
          "**/*.mkv"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "SIKFilm",
    "copyright": "Copyright © SIKFilm",
    "shortDescription": "SIK Render",
    "longDescription": "Local Blender render queue and LAN node monitor for SIKFilm workflows.",
    "resources": [
      "bin/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
